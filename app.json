{
  "configVersion": "v3",
  "app": {
    "appId": 1106856,
    "appType": "app",
    "appName": "Voice Bridge",
    "version": {
      "code": 2,
      "name": "1.1.0"
    },
    "icon": "icon.png",
    "vender": "Piotr Loch",
    "description": "Dictate on your Amazfit watch and send transcribed text as a JSON webhook to any HTTPS endpoint (n8n, Home Assistant, Zapier, your API). Requires Zepp App on a paired phone for settings and HTTP delivery. No message history is stored on the watch."
  },
  "permissions": [
    "device:os.keyboard",
    "data:os.device.info"
  ],
  "runtime": {
    "apiVersion": {
      "compatible": "4.0",
      "target": "4.0",
      "minVersion": "4.0"
    }
  },
  "debug": false,
  "targets": {
    "gt": {
      "module": {
        "page": {
          "pages": [
            "page/index"
          ]
        },
        "app-side": {
          "path": "app-side/index"
        },
        "setting": {
          "path": "settings/index"
        }
      },
      "platforms": [
        {
          "st": "r"
        }
      ],
      "designWidth": 336
    }
  },
  "i18n": {
    "en-US": {
      "appName": "Voice Bridge"
    },
    "pl-PL": {
      "appName": "Voice Bridge"
    }
  },
  "defaultLanguage": "en-US"
}
